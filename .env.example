# ─── DATABASE ───────────────────────────────────────────────────────────────
# PostgreSQL connection string — update with your local or cloud DB
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bulkap?schema=public"

# ─── AUTH ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string-in-production"

# ─── AWS S3 (Document Storage) ───────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
S3_BUCKET="bulkap-documents"

# ─── ORACLE CLOUD (per-tenant — these are defaults, overridden per tenant in DB) ──
ORACLE_HCM_BASE_URL="https://your-oracle-instance.oraclecloud.com"
ORACLE_HCM_USERNAME="service_account@company.com"
ORACLE_HCM_PASSWORD="your-service-account-password"

# ─── AZURE DOCUMENT INTELLIGENCE (AI Extraction) ─────────────────────────────
AZURE_DOC_INTEL_ENDPOINT="https://your-resource.cognitiveservices.azure.com"
AZURE_DOC_INTEL_KEY="your-azure-key"

# ─── KAFKA (optional — set KAFKA_ENABLED=false to disable) ───────────────────
KAFKA_ENABLED="false"
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="bulkap-producer"

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"